# MongoDB Connection
# For local development: mongodb://localhost:27017/travelyt
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/travelyt?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/travelyt

# Session Secret (for cookie signing)
SESSION_SECRET=your-secret-key-change-in-production

# Environment
NODE_ENV=development
